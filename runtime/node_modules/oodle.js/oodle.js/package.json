{
    "name": "oodle.js",
    "version": "2.0.3",
    "description": "Simple Oodle data compression wrapper",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "type": "module",
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "bin"
    ],
    "scripts": {
        "build": "tsup",
        "lint": "npx @biomejs/biome check .",
        "format": "npx @biomejs/biome format . --write",
        "check": "npx @biomejs/biome check . --write"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/backiscute/oodle.js.git"
    },
    "author": {
        "name": "Back",
        "email": "me@back.rs",
        "url": "https://back.rs"
    },
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/backiscute/oodle.js/issues"
    },
    "homepage": "https://github.com/backiscute/oodle.js#readme",
    "keywords": [
        "oodle",
        "compression",
        "decompression",
        "unreal engine",
        "unrealengine",
        "ue4",
        "ue5",
        "fortnite",
        "valorant"
    ],
    "dependencies": {
        "koffi": "^2.14.0",
        "node-stream-zip": "^1.15.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@types/bun": "latest",
        "tsup": "^8.5.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
